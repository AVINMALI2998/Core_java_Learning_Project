<?xml version="1.0" encoding="UTF-8"?>
<suite name="Hydra Hybrid Framework Test Suite" verbose="2" thread-count="1" parallel="methods">

    <!-- Define Test Parameters -->
    <parameter name="browser" value="chrome" />

    <!-- Google Search Tests -->
    <test name="Google Search Tests">
        <classes>
            <class name="com.hydra.tests.GoogleSearchTest">
                <methods>
                    <include name="testGoogleSearch" />
                    <include name="testGooglePageTitle" />
                    <include name="testClearSearchBox" />
                </methods>
            </class>
        </classes>
    </test>

    <!-- Login Page Tests -->
    <test name="Login Page Tests">
        <classes>
            <class name="com.hydra.tests.LoginPageTest">
                <methods>
                    <include name="testLoginPageDisplay" />
                    <include name="testSuccessfulLogin" />
                    <include name="testLoginWithInvalidCredentials" />
                    <include name="testRememberMeCheckbox" />
                    <include name="testForgotPasswordLink" />
                </methods>
            </class>
        </classes>
    </test>

    <!-- Smoke Test Suite -->
    <test name="Smoke Tests" enabled="true">
        <classes>
            <class name="com.hydra.tests.GoogleSearchTest">
                <methods>
                    <include name="testGoogleSearch" />
                </methods>
            </class>
            <class name="com.hydra.tests.LoginPageTest">
                <methods>
                    <include name="testLoginPageDisplay" />
                </methods>
            </class>
        </classes>
    </test>

</suite>
